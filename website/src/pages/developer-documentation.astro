---
import {getCollection} from 'astro:content';
import {devDocsRoot} from "../layouts/developer-docs/config.ts";

const urlBase: string = import.meta.env.BASE_URL.replace(/\/$/, '');

const pagesDocs = Object.values(
    import.meta.glob('./developer-documentation/*.md', {eager: true})
).map((doc: any) => ({
    url: doc.url,
    order: doc.frontmatter.order ?? 0,
    parent: doc.frontmatter.parent,
}));

const collectionDocs = (await getCollection('devDocs')).map((doc: any) => ({
    url: `${urlBase}/${devDocsRoot}/${doc.id}`,
    order: doc.data.order ?? 0,
    parent: doc.data.parent,
}));

const firstDoc = [...pagesDocs, ...collectionDocs]
    .filter(doc => !doc.parent)
    .sort((a, b) => a.order - b.order)
    [0];

export const frontmatter = {order: Infinity};

return Astro.rewrite(firstDoc.url);
---